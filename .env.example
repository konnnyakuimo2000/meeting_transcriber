# Claude API キー (https://console.anthropic.com/ で取得)
ANTHROPIC_API_KEY=your_api_key_here

# Whisperモデルサイズ (tiny/base/small/medium/large-v3)
# 大きいほど精度が高いが遅い。medium が推奨。
WHISPER_MODEL=medium

# HuggingFace Access Token（話者識別に必要）
# 1. https://huggingface.co/settings/tokens でトークン取得
# 2. https://huggingface.co/pyannote/speaker-diarization-3.1 で利用規約に同意
# トークンなしでも起動可能（話者識別OFF時は不要）
HF_TOKEN=
