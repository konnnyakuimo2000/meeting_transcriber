# ── AIプロバイダー設定 ──────────────────────────────────────────────
# 使用するプロバイダーを明示する場合のみ設定（省略時は設定済みAPIキーから自動検出）
# AI_PROVIDER=anthropic   # anthropic / openai / gemini

# Anthropic Claude (https://console.anthropic.com/ で取得)
ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com/api-keys で取得)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o   # gpt-4o / gpt-4-turbo など

# Google Gemini (https://aistudio.google.com/app/apikey で取得)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro   # gemini-1.5-pro / gemini-1.5-flash など

# ── Whisper設定 ──────────────────────────────────────────────────────
# モデルサイズ (tiny/base/small/medium/large-v3)  大きいほど精度が高いが遅い
WHISPER_MODEL=medium

# ── 話者識別 ─────────────────────────────────────────────────────────
# HuggingFace Access Token（話者識別を使う場合のみ）
# 1. https://huggingface.co/settings/tokens でトークン取得
# 2. https://huggingface.co/pyannote/speaker-diarization-3.1 で利用規約に同意
HF_TOKEN=
